        "hide": 0,
        "includeAll": false,
        "label": "uri",
        "multi": false,
        "name": "uri",
        "options": [],
        "query": {"query": "label_values(http_server_requests_seconds_count{application=~\"$app\"}, uri)", "refId": "Prometheus-uri"},
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Sugang Performance Dashboard",
  "uid": "sugang-performance",
  "version": 1,
  "weekStart": ""
}
