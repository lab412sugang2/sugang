{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$app\"}[1m]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "title": "RPS (All)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_requests_seconds_count{application=~\"$app\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=~\"$app\"}[1m]))",
          "legendFormat": "5xx Error %",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx %)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.8},
              {"color": "red", "value": 1.5}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=~\"$app\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=~\"$app\"}[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "title": "HTTP Latency (p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 4,
      "targets": [
        {"expr": "process_cpu_usage{application=~\"$app\"}", "legendFormat": "process", "refId": "A"},
        {"expr": "system_cpu_usage{application=~\"$app\"}", "legendFormat": "system", "refId": "B"}
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 70},
              {"color": "red", "value": 85}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 5,
      "targets": [
        {
          "expr": "100 * sum(jvm_memory_used_bytes{application=~\"$app\",area=\"heap\"}) / sum(jvm_memory_max_bytes{application=~\"$app\",area=\"heap\"})",
          "legendFormat": "heap used %",
          "refId": "A"
        }
      ],
      "title": "Heap Usage %",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(jvm_gc_pause_seconds_bucket{application=~\"$app\"}[5m])))",
          "legendFormat": "GC pause p95",
          "refId": "A"
        }
      ],
      "title": "GC Pause p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "id": 7,
      "targets": [
        {
          "expr": "100 * max(hikaricp_connections_active{application=~\"$app\",pool=~\"$pool\"}) / max(hikaricp_connections_max{application=~\"$app\",pool=~\"$pool\"})",
          "legendFormat": "active/max %",
          "refId": "A"
        }
      ],
      "title": "Hikari Active/Max %",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "id": 8,
      "targets": [
        {
          "expr": "max(hikaricp_connections_pending{application=~\"$app\",pool=~\"$pool\"})",
          "legendFormat": "pending",
          "refId": "A"
        },
        {
          "expr": "increase(hikaricp_connections_timeout_total{application=~\"$app\",pool=~\"$pool\"}[5m])",
          "legendFormat": "timeout increase(5m)",
          "refId": "B"
        }
      ],
      "title": "Hikari Pending / Timeout",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "id": 9,
      "targets": [
        {
          "expr": "100 * max(tomcat_threads_busy_threads{application=~\"$app\"}) / max(tomcat_threads_config_max_threads{application=~\"$app\"})",
          "legendFormat": "busy/max %",
          "refId": "A"
        }
      ],
      "title": "Tomcat Busy/Max %",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "id": 10,
      "targets": [
        {
          "expr": "topk(5, sum by (uri) (rate(http_server_requests_seconds_count{application=~\"$app\"}[1m])))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "title": "Top 5 URI RPS",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "id": 11,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=~\"$app\",uri=~\"$uri\"}[5m])))",
          "legendFormat": "{{uri}} p95",
          "refId": "A"
        }
      ],
      "title": "URI p95 Latency",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["sugang", "performance", "micrometer"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "All", "value": ".*"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(http_server_requests_seconds_count, application)",
        "hide": 0,
        "includeAll": true,
        "label": "application",
        "multi": false,
        "name": "app",
        "options": [],
        "query": {"query": "label_values(http_server_requests_seconds_count, application)", "refId": "Prometheus-app"},
        "refresh": 1,
