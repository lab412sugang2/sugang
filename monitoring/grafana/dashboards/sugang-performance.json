      },
      {
        "current": {"selected": false, "text": "All", "value": ".*"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(hikaricp_connections_active{application=~\"$app\"}, pool)",
        "hide": 0,
        "includeAll": true,
        "label": "pool",
        "multi": false,
        "name": "pool",
        "options": [],
        "query": {"query": "label_values(hikaricp_connections_active{application=~\"$app\"}, pool)", "refId": "Prometheus-pool"},
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {"selected": true, "text": "/saveTkcrsApl.do", "value": "/saveTkcrsApl.do"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
